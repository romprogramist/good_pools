DATABASE_URL=postgres://roman:Test1234@localhost:5432/good_pools_db
SESSION_SECRET=change-me-to-random-string
PORT=3050

# Yandex SMTP for lead notifications (POST /api/leads → e-mail).
# Получить app-пароль: https://id.yandex.ru/security/app-passwords
# (раздел «Безопасность» → «Пароли приложений» → тип «Почта»).
# IMAP должен быть включён: https://mail.yandex.ru/?#setup/client
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=your-mailbox@yandex.ru
SMTP_PASS=your-16-char-app-password
MAIL_TO=where-to-send-leads@yandex.ru
MAIL_FROM_NAME=GoodBass — заявка с сайта

# Telegram-бот для дублирования заявок (POST /api/leads → TG).
# 1. Открой @BotFather в Telegram → /newbot → имя → username → получишь токен.
# 2. Напиши боту /start (или добавь в группу и отправь любое сообщение).
# 3. Открой https://api.telegram.org/bot<TOKEN>/getUpdates → найди chat.id.
#    Для группы id отрицательный, например -1001234567890.
# Если переменные пусты — модуль молча ничего не отправляет (см. lib/telegram.js).
# TELEGRAM_CHAT_ID поддерживает несколько ID через запятую: 168614886,5912441830
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
